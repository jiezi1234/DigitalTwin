# Flask RAG 聊天机器人配置文件

# Qwen API配置 (同时用于DashScope Embedding)
QWEN_API_KEY=your_dashscope_api_key_here
QWEN_MODEL=qwen-plus

# ChromaDB 本地向量数据库配置（无需安装数据库服务器）
# 向量数据存储在本地文件夹中
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=wechat_embeddings

# RAG配置
RAG_ENABLED=true
RAG_MAX_RESULTS=20
RAG_MAX_CONTEXT_LENGTH=2000
RAG_INCLUDE_METADATA=true

# Flask服务配置
FLASK_HOST=0.0.0.0
FLASK_PORT=8080
FLASK_DEBUG=false

# 模型参数配置
TEMPERATURE=0.5
TOP_P=0.7
MAX_TOKENS=500
REPETITION_PENALTY=1.2
