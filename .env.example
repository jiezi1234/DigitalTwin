# Flask RAG 聊天机器人配置文件

# API配置
DASHSCOPE_API_KEY=your_dashscope_api_key_here
CHAT_MODEL=qwen-plus
EMBED_MODEL=text-embedding-v4

# 用于RAG优化（Query Rewriting和指代消解）的大模型API配置
# LLM_API_BASE 应为 OpenAI 兼容的 API 基础URL（不包含 /v1/chat/completions）
# 例如：https://api.openai.com 或 https://dashscope.aliyuncs.com/compatible-mode
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode
LLM_REWRITING_MODEL=qwen-plus

# RAG检索优化配置
# 是否启用 Query Rewriting（改写查询以提高检索质量）
RAG_QUERY_REWRITING_ENABLED=true
# 是否启用指代消解（将代词替换为具体人名）
RAG_COREFERENCE_RESOLUTION_ENABLED=true

# 日志配置
# 日志级别: DEBUG（详细）/ INFO（默认）/ WARNING / ERROR
LOG_LEVEL=INFO
# 日志文件路径（支持相对路径）
LOG_FILE=logs/app.log
# 单个日志文件最大字节数（默认 10 MB）
LOG_MAX_BYTES=10485760
# 日志文件保留数量（轮转备份数）
LOG_BACKUP_COUNT=5

# CSV 数据源配置（支持 glob 通配符，如 *.csv 导入全部，或指定单个文件名）
CSV_FILE_PATTERN=zhenhuan_chat.csv

# ChromaDB 本地向量数据库配置（无需安装数据库服务器）
# 向量数据存储在本地文件夹中
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=wechat_embeddings

# RAG配置
RAG_ENABLED=true
RAG_MAX_RESULTS=20
RAG_MAX_CONTEXT_LENGTH=2000
RAG_INCLUDE_METADATA=true

# 课本 OCR 配置（数字助教，用于图片型扫描 PDF）
# OCR 识别语言（Tesseract 语言代码，多语言用 + 连接）
TUTOR_OCR_LANGUAGE=chi_sim+eng
# OCR 渲染分辨率（dpi），越高精度越好但越慢，建议 150-300
TUTOR_OCR_DPI=150
# 并行 OCR 线程数（0=自动，建议根据 CPU 核心数设置，如 4 或 8）
TUTOR_OCR_WORKERS=0
# 页面文字数低于此阈值才触发 OCR（0=禁用OCR，-1=强制所有页面都OCR）
TUTOR_OCR_TEXT_THRESHOLD=50

# Flask服务配置
FLASK_HOST=0.0.0.0
FLASK_PORT=8080
FLASK_DEBUG=false

# 模型参数配置
TEMPERATURE=0.5
TOP_P=0.7
MAX_TOKENS=500
REPETITION_PENALTY=1.2
